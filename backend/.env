# Pan Pacific Backend Configuration

# Server
PORT=5003
HTTP_PORT=5004
ENABLE_HTTP_REDIRECT=false
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/pan-pacific
STORAGE_TYPE=mongodb

# JWT Settings
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=24h

# CORS
CORS_ORIGIN=https://panpacific.com.np
CORS_ORIGINS=http://panpacific.com.np,https://panpacific.com.np,http://www.panpacific.com.np,https://www.panpacific.com.np

# Mail (Contact & Quote forms) – use your email and 16-digit App Password
# Gmail: use App Password from Google Account → Security → 2-Step Verification → App passwords
MAIL=info@panpacific.com.np
EMAIL_APP_PASSWORD=panpacific@12345
# SMTP (hosting panel / custom mail server)
SMTP_HOST=mail.panpacific.com.np
SMTP_PORT=587
SMTP_USER=info@panpacific.com.np
SMTP_PASS=panpacific@12345
EMAIL_SECURE=false
EMAIL_FROM=info@panpacific.com.np
ADMIN_EMAIL=info@panpacific.com.np
# Optional: where to receive contact/quote notifications (defaults to MAIL)
# ADMIN_EMAIL=admin@yourdomain.com
